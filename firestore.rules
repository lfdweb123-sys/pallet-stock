rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Commandes : créées et modifiées UNIQUEMENT via les routes /api (Firebase Admin SDK,
    // qui ignore ces règles). Le client peut seulement LIRE ses propres commandes :
    // - soit parce que son uid correspond à celui enregistré sur la commande (compte utilisé au moment du paiement)
    // - soit parce que son email correspond à l'email client de la commande (commande passée en invité)
    match /orders/{orderId} {
      allow read: if request.auth != null && (
        request.auth.uid == resource.data.uid
        || request.auth.token.email == resource.data.customer.email
      );
      allow write: if false;
    }
    // Par défaut, tout le reste est bloqué.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}